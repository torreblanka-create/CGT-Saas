# ─────────────────────────────────────────────────────────────────────
# EJEMPLO de secrets para Streamlit Community Cloud
# → Copia este contenido en el panel "Secrets" de share.streamlit.io
# → NUNCA subas el secrets.toml real a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────

# Contraseñas iniciales de usuarios semilla
# Si no se definen, el sistema usa el fallback "cgt_init_2026"
ADMIN_PASSWORD   = "cambia_esto_antes_de_produccion"
RIGGER_PASSWORD  = "cambia_esto_antes_de_produccion"
VISITA_PASSWORD  = "cambia_esto_antes_de_produccion"
AUDITOR_PASSWORD = "cambia_esto_antes_de_produccion"

# API Key de Google Gemini (para Ull-Trone AI)
# También se puede configurar desde el panel de administración de la app
GEMINI_API_KEY = ""
