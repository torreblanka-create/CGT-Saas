# ==========================================
# STREAMLIT CLOUD - SECRETOS (secrets.toml)
# ==========================================
# INSTRUCCIONES:
# 1. Copiar este contenido (SIN el .example)
# 2. Ir a Streamlit Cloud → App settings → Secrets
# 3. Pegar el contenido y reemplazar [valores-aqui]
# 4. Hacer DEPLOY

# Turso Database (OBLIGATORIO en produccion)
TURSO_ENV = "sync"
LIBSQL_DB_URL = "libsql://cgt-saas-prod-[org].turso.io"
LIBSQL_DB_AUTH_TOKEN = "[token-largo-aqui]"

# Contraseñas iniciales del sistema
ADMIN_PASSWORD = "ADMIN_CGT_2024"
RIGGER_PASSWORD = "RIGGER_CGT_2024"
VISITA_PASSWORD = "VISITA_CGT_2024"
AUDITOR_PASSWORD = "AUDITOR_CGT_2024"

# Google Gemini AI API Key (opcional)
# GEMINI_API_KEY = "[api-key-aqui]"
