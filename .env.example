# ==========================================
# CGT SaaS - Variables de Entorno (Ejemplo)
# ==========================================
# Copie este archivo como .env y complete los valores reales.
# NUNCA suba el archivo .env al repositorio.

# Modo de base de datos: "local" (desarrollo) o "sync" (producción)
TURSO_ENV=local

# Turso Database (solo necesario en modo "sync")
LIBSQL_DB_URL=
LIBSQL_DB_AUTH_TOKEN=

# Contraseñas iniciales del sistema
ADMIN_PASSWORD=
RIGGER_PASSWORD=
VISITA_PASSWORD=
AUDITOR_PASSWORD=

# Google Gemini AI API Key
GEMINI_API_KEY=
